# Database — SQLite for local dev; use PostgreSQL in production (see docker-compose.yml)
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth)
NEXTAUTH_SECRET="change-this-to-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Business (GST invoicing)
BUSINESS_GSTIN=""
BUSINESS_STATE="Maharashtra"

# Razorpay (Module 6)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Image storage — Cloudinary OR S3 (Module 2)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email — Resend or SMTP (Module 6+)
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
